@model EShop.Models.Product
@{
    ViewData["Title"] = Model.Name;
    
    var allImages = new List<string>();
    // Main image from Products table
    if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        allImages.Add(Model.ImageUrl);
    }
    // Additional images from ProductImages table (only IsMain = false)
    if (Model.Images != null)
    {
        foreach (var img in Model.Images.Where(i => !i.IsMain))
        {
            if (!string.IsNullOrEmpty(img.ImageUrl))
            {
                allImages.Add(img.ImageUrl);
            }
        }
    }
    // Fallback if no images
    if (!allImages.Any())
    {
        allImages.Add($"https://picsum.photos/seed/product{Model.Id}/800/800");
    }
}

<style>
    .product-gallery-main {
        position: relative;
        width: 100%;
        height: 500px;
        border-radius: 16px;
        overflow: hidden;
        background: var(--white);
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    }
    .product-gallery-main img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }
    .product-gallery-main:hover img {
        transform: scale(1.05);
    }
    .product-gallery-thumbs {
        display: flex;
        gap: 12px;
        margin-top: 16px;
        overflow-x: auto;
        padding-bottom: 8px;
    }
    .product-gallery-thumbs button {
        flex-shrink: 0;
        width: 80px;
        height: 80px;
        border-radius: 12px;
        overflow: hidden;
        border: 3px solid transparent;
        cursor: pointer;
        transition: all 0.3s ease;
        padding: 0;
    }
    .product-gallery-thumbs button.active {
        border-color: var(--accent-orange);
    }
    .product-gallery-thumbs button img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .product-tabs {
        display: flex;
        gap: 8px;
        border-bottom: 2px solid var(--gray-light);
        margin-bottom: 30px;
    }
    .product-tab {
        padding: 16px 32px;
        background: none;
        border: none;
        font-size: 16px;
        font-weight: 600;
        color: var(--gray);
        cursor: pointer;
        position: relative;
        transition: all 0.3s ease;
    }
    .product-tab.active {
        color: var(--accent-orange);
    }
    .product-tab.active::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 100%;
        height: 3px;
        background: var(--accent-orange);
    }
    .product-specs {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
    }
    .spec-item {
        display: flex;
        padding: 16px;
        background: var(--off-white);
        border-radius: 12px;
        align-items: center;
        gap: 16px;
    }
    .spec-item i {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--primary-navy);
        color: white;
        border-radius: 12px;
        font-size: 20px;
    }
    .spec-item strong {
        display: block;
        color: var(--primary-navy);
        font-size: 14px;
    }
    .spec-item span {
        color: var(--gray);
        font-size: 13px;
    }
    .qty-selector {
        display: flex;
        align-items: center;
        gap: 0;
        border: 2px solid var(--gray-light);
        border-radius: 12px;
        overflow: hidden;
    }
    .qty-selector button {
        width: 48px;
        height: 48px;
        border: none;
        background: var(--off-white);
        font-size: 18px;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .qty-selector button:hover {
        background: var(--accent-orange);
        color: white;
    }
    .qty-selector input {
        width: 60px;
        height: 48px;
        border: none;
        text-align: center;
        font-size: 18px;
        font-weight: 600;
        -moz-appearance: textfield;
    }
    .qty-selector input::-webkit-outer-spin-button,
    .qty-selector input::-webkit-inner-spin-button {
        -webkit-appearance: none;
    }
    .share-buttons {
        display: flex;
        gap: 12px;
    }
    .share-buttons a {
        width: 44px;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        background: var(--off-white);
        color: var(--primary-navy);
        transition: all 0.3s ease;
    }
    .share-buttons a:hover {
        background: var(--accent-orange);
        color: white;
    }
</style>

<div class="container product-detail" style="padding: 40px 20px;">
    <!-- Breadcrumb -->
    <nav style="margin-bottom: 30px;">
        <ol style="display: flex; gap: 8px; list-style: none; padding: 0; margin: 0; font-size: 14px; color: var(--gray);">
            <li><a href="/" style="color: var(--primary-navy); text-decoration: none;">خانه</a></li>
            <li>/</li>
            <li><a href="/Products" style="color: var(--primary-navy); text-decoration: none;">محصولات</a></li>
            <li>/</li>
            <li><a href="/Products?category=@Model.CategoryId" style="color: var(--primary-navy); text-decoration: none;">@Model.Category?.Name</a></li>
            <li>/</li>
            <li style="color: var(--accent-orange);">@Model.Name</li>
        </ol>
    </nav>

    <div class="product-detail-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 60px; margin-bottom: 60px;">
        <!-- Gallery -->
        <div>
            <div class="product-gallery-main">
                <img id="mainImage" src="@allImages.First()" alt="@Model.Name" />
            </div>
            @if (allImages.Count > 1)
            {
                <div class="product-gallery-thumbs">
                    @for (int i = 0; i < allImages.Count; i++)
                    {
                        <button class="@(i == 0 ? "active" : "")" onclick="changeImage('@allImages[i]', this)">
                            <img src="@allImages[i]" alt="Product image @(i + 1)" />
                        </button>
                    }
                </div>
            }
            
            <!-- Video Section -->
            @if (Model.Videos != null && Model.Videos.Any())
            {
                <div style="margin-top: 20px;">
                    <h4 style="color: var(--primary-navy); margin-bottom: 15px;"><i class="fas fa-video"></i> ویدئوی محصول</h4>
                    <div style="display: flex; flex-wrap: wrap; gap: 15px;">
                        @foreach (var video in Model.Videos)
                        {
                            <div style="width: 100%; max-width: 400px; border-radius: 12px; overflow: hidden; background: #000;">
                                @if (video.VideoUrl.Contains("youtube.com") || video.VideoUrl.Contains("youtu.be"))
                                {
                                    <iframe width="100%" height="225" src="@video.VideoUrl.Replace("watch?v=", "embed/")" frameborder="0" allowfullscreen style="border-radius: 12px;"></iframe>
                                }
                                else if (video.VideoUrl.StartsWith("/uploads/"))
                                {
                                    <video controls style="width: 100%; border-radius: 12px;">
                                        <source src="@video.VideoUrl" type="video/mp4">
                                        مرورگر شما ویدئو را پشتیبانی نمی‌کند
                                    </video>
                                }
                                else
                                {
                                    <a href="@video.VideoUrl" target="_blank" style="display: block; padding: 40px; background: #333; color: white; text-align: center; border-radius: 12px; text-decoration: none;">
                                        <i class="fas fa-play-circle" style="font-size: 40px; margin-bottom: 10px;"></i><br>
                                        مشاهده ویدئو
                                    </a>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Info -->
        <div>
            <div style="margin-bottom: 12px;">
                <span style="background: var(--accent-orange); color: white; padding: 6px 16px; border-radius: 20px; font-size: 13px; font-weight: 600;">
                    @Model.Category?.Name
                </span>
                @if (Model.IsFeatured)
                {
                    <span style="background: var(--primary-navy); color: white; padding: 6px 16px; border-radius: 20px; font-size: 13px; font-weight: 600; margin-right: 8px;">
                        ویژه
                    </span>
                }
            </div>

            <h1 style="font-size: 32px; color: var(--primary-navy); margin-bottom: 20px; line-height: 1.3;">@Model.Name</h1>

            <!-- Rating -->
            <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 24px;">
                <div style="display: flex; gap: 4px; color: #ffc107;">
                    <i class="fas fa-star"></i>
                    <i class="fas fa-star"></i>
                    <i class="fas fa-star"></i>
                    <i class="fas fa-star"></i>
                    <i class="fas fa-star-half-alt"></i>
                </div>
                <span style="color: var(--gray); font-size: 14px;">4.5 (128 نظر)</span>
            </div>

            <!-- Price -->
            <div style="margin-bottom: 24px;">
                @if (Model.DiscountPrice.HasValue && Model.DiscountPrice > 0)
                {
                    <span style="font-size: 36px; font-weight: 700; color: var(--accent-orange);">@((Model.DiscountPrice.Value).ToString("N0")) تومان</span>
                    <span style="font-size: 20px; color: var(--gray); text-decoration: line-through; margin-right: 16px;">@Model.Price.ToString("N0") تومان</span>
                    <span style="background: #dc3545; color: white; padding: 6px 12px; border-radius: 8px; font-size: 14px; font-weight: 600; margin-right: 12px;">
                        @(((Model.Price - Model.DiscountPrice.Value) / Model.Price * 100).ToString("F0"))٪ تخفیف
                    </span>
                }
                else
                {
                    <span style="font-size: 36px; font-weight: 700; color: var(--accent-orange);">@Model.Price.ToString("N0") تومان</span>
                }
            </div>

            <!-- Stock Status -->
            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 24px; padding: 12px 16px; background: @(Model.Stock > 0 ? "#d4edda" : "#f8d7da"); border-radius: 8px;">
                <i class="fas fa-@(Model.Stock > 0 ? "check-circle" : "times-circle")" style="color: @(Model.Stock > 0 ? "#155724" : "#721c24");"></i>
                <span style="color: @(Model.Stock > 0 ? "#155724" : "#721c24"); font-weight: 600;">
                    @(Model.Stock > 0 ? $"موجود در انبار ({Model.Stock} عدد)" : "ناموجود")
                </span>
            </div>

            <!-- Description -->
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <p style="color: var(--gray-dark); line-height: 1.8; margin-bottom: 24px;">@Model.Description</p>
            }

            <!-- Add to Cart -->
            @if (Model.Stock > 0)
            {
                <form asp-controller="Cart" asp-action="AddToCart" method="post" style="display: flex; gap: 16px; margin-bottom: 30px;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@Model.Id" />
                    <div class="qty-selector">
                        <button type="button" onclick="updateQty(-1)">-</button>
                        <input type="number" id="qtyInput" name="quantity" value="1" min="1" max="@Model.Stock" />
                        <button type="button" onclick="updateQty(1)">+</button>
                    </div>
                    <button type="submit" class="btn btn-primary" style="flex: 1; height: 52px; font-size: 16px;">
                        <i class="fas fa-shopping-cart"></i> افزودن به سبد خرید
                    </button>
                </form>
            }

            <!-- Meta Info -->
            <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin-bottom: 30px;">
                <div style="background: var(--off-white); padding: 16px; border-radius: 12px;">
                    <span style="color: font-size:  var(--gray);13px;">کد محصول</span>
                    <strong style="display: block; color: var(--primary-navy);">@(Model.SKU ?? $"ESH-{Model.Id:D4}")</strong>
                </div>
                <div style="background: var(--off-white); padding: 16px; border-radius: 12px;">
                    <span style="color: var(--gray); font-size: 13px;">دسته‌بندی</span>
                    <strong style="display: block; color: var(--primary-navy);">@Model.Category?.Name</strong>
                </div>
            </div>

            <!-- Share -->
            <div style="display: flex; align-items: center; gap: 16px;">
                <span style="color: var(--gray);">اشتراک‌گذاری:</span>
                <div class="share-buttons">
                    <a href="#" title="Facebook"><i class="fab fa-facebook-f"></i></a>
                    <a href="#" title="Twitter"><i class="fab fa-twitter"></i></a>
                    <a href="#" title="WhatsApp"><i class="fab fa-whatsapp"></i></a>
                    <a href="#" title="Telegram"><i class="fab fa-telegram-plane"></i></a>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabs -->
    <div class="product-tabs">
        <button class="product-tab active" onclick="showTab('desc', this)">توضیحات</button>
        <button class="product-tab" onclick="showTab('specs', this)">مشخصات</button>
        <button class="product-tab" onclick="showTab('reviews', this)">نظرات (128)</button>
    </div>

    <!-- Tab Content: Description -->
    <div id="tab-desc" class="tab-content">
        <div style="background: var(--white); padding: 40px; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.08);">
            <h3 style="color: var(--primary-navy); margin-bottom: 20px;">توضیحات محصول</h3>
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <p style="line-height: 1.8; color: var(--gray-dark); white-space: pre-line;">@Model.Description</p>
            }
            else
            {
                <p style="color: var(--gray);">توضیحاتی برای این محصول ثبت نشده است.</p>
            }
        </div>
    </div>

    <!-- Tab Content: Specifications -->
    <div id="tab-specs" class="tab-content" style="display: none;">
        <div style="background: var(--white); padding: 40px; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.08);">
            <h3 style="color: var(--primary-navy); margin-bottom: 30px;">مشخصات فنی</h3>
            
            @if (Model.Attributes != null && Model.Attributes.Any())
            {
                <div class="product-specs">
                    @foreach (var attr in Model.Attributes)
                    {
                        <div class="spec-item">
                            <i class="fas fa-check"></i>
                            <div>
                                <strong>@attr.Name</strong>
                                <span>@attr.Value</span>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p style="color: var(--gray);">مشخصاتی برای این محصول ثبت نشده است.</p>
            }

            <h4 style="color: var(--primary-navy); margin: 30px 0 20px;">اطلاعات عمومی</h4>
            <div class="product-specs">
                <div class="spec-item">
                    <i class="fas fa-tag"></i>
                    <div><strong>دسته‌بندی</strong><span>@Model.Category?.Name</span></div>
                </div>
                <div class="spec-item">
                    <i class="fas fa-barcode"></i>
                    <div><strong>کد محصول</strong><span>@(Model.SKU ?? $"ESH-{Model.Id:D4}")</span></div>
                </div>
                <div class="spec-item">
                    <i class="fas fa-box"></i>
                    <div><strong>موجودی</strong><span>@Model.Stock عدد</span></div>
                </div>
                <div class="spec-item">
                    <i class="fas fa-calendar"></i>
                    <div><strong>تاریخ اضافه شدن</strong><span>@Model.CreatedAt.ToString("yyyy/MM/dd")</span></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tab Content: Reviews -->
    <div id="tab-reviews" class="tab-content" style="display: none;">
        <div style="background: var(--white); padding: 40px; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.08);">
            <h3 style="color: var(--primary-navy); margin-bottom: 20px;">نظرات کاربران</h3>
            
            <div style="display: flex; align-items: center; gap: 20px; margin-bottom: 30px; padding-bottom: 30px; border-bottom: 1px solid var(--gray-light);">
                <div style="text-align: center;">
                    <div style="font-size: 48px; font-weight: 700; color: var(--primary-navy);">4.5</div>
                    <div style="display: flex; gap: 4px; color: #ffc107; justify-content: center; margin: 8px 0;">
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star-half-alt"></i>
                    </div>
                    <span style="color: var(--gray); font-size: 14px;">128 نظر</span>
                </div>
                <div style="flex: 1;">
                    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
                        <span style="font-size: 13px; width: 30px;">5</span>
                        <div style="flex: 1; height: 8px; background: var(--gray-light); border-radius: 4px; overflow: hidden;">
                            <div style="width: 70%; height: 100%; background: #ffc107;"></div>
                        </div>
                        <span style="font-size: 13px; color: var(--gray);">70%</span>
                    </div>
                    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
                        <span style="font-size: 13px; width: 30px;">4</span>
                        <div style="flex: 1; height: 8px; background: var(--gray-light); border-radius: 4px; overflow: hidden;">
                            <div style="width: 20%; height: 100%; background: #ffc107;"></div>
                        </div>
                        <span style="font-size: 13px; color: var(--gray);">20%</span>
                    </div>
                    <div style="display: flex; align-items: center; gap: 12px;">
                        <span style="font-size: 13px; width: 30px;">3</span>
                        <div style="flex: 1; height: 8px; background: var(--gray-light); border-radius: 4px; overflow: hidden;">
                            <div style="width: 10%; height: 100%; background: #ffc107;"></div>
                        </div>
                        <span style="font-size: 13px; color: var(--gray);">10%</span>
                    </div>
                </div>
            </div>

            <div style="text-align: center; padding: 40px;">
                <i class="fas fa-comments" style="font-size: 48px; color: var(--gray-light); margin-bottom: 16px;"></i>
                <p style="color: var(--gray);">هنوز نظری برای این محصول ثبت نشده است.</p>
                <button class="btn btn-primary" style="margin-top: 16px;">ثبت نظر</button>
            </div>
        </div>
    </div>

    <!-- Related Products -->
    @if (ViewBag.RelatedProducts != null && ((List<EShop.Models.Product>)ViewBag.RelatedProducts).Any())
    {
        <div class="section-title" style="margin-top: 60px;">
            <h2>محصولات مرتبط</h2>
            <div class="line"></div>
        </div>
        <div class="products-grid">
            @foreach (var product in (List<EShop.Models.Product>)ViewBag.RelatedProducts)
            {
                <div class="product-card">
                    <div class="product-image">
                        <img src="@product.ImageUrl" alt="@product.Name" onerror="this.src='https://picsum.photos/seed/product/@product.Id/400/400'" />
                        @if (product.DiscountPrice.HasValue)
                        {
                            <span class="product-badge">@(((product.Price - product.DiscountPrice.Value) / product.Price * 100).ToString("F0"))%</span>
                        }
                        <div class="product-actions">
                            <form asp-controller="Cart" asp-action="AddToCart" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@product.Id" />
                                <button type="submit" title="افزودن به سبد"><i class="fas fa-shopping-cart"></i></button>
                            </form>
                            <a href="/Products/Details/@product.Id" title="مشاهده"><i class="fas fa-eye"></i></a>
                        </div>
                    </div>
                    <div class="product-info">
                        <div class="product-category">@product.Category?.Name</div>
                        <h3 class="product-name">@product.Name</h3>
                        <div class="product-price">
                            <span class="current-price">@((product.DiscountPrice ?? product.Price).ToString("N0")) تومان</span>
                            @if (product.DiscountPrice.HasValue)
                            {
                                <span class="original-price">@product.Price.ToString("N0") تومان</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<script>
    function changeImage(src, btn) {
        document.getElementById('mainImage').src = src;
        document.querySelectorAll('.product-gallery-thumbs button').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
    }

    function updateQty(delta) {
        const input = document.getElementById('qtyInput');
        let val = parseInt(input.value) + delta;
        const max = parseInt(input.max);
        if (val < 1) val = 1;
        if (val > max) val = max;
        input.value = val;
    }

    function showTab(tabName, btn) {
        document.querySelectorAll('.tab-content').forEach(t => t.style.display = 'none');
        document.querySelectorAll('.product-tab').forEach(t => t.classList.remove('active'));
        document.getElementById('tab-' + tabName).style.display = 'block';
        btn.classList.add('active');
    }
</script>
