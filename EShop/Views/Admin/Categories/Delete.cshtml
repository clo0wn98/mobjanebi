@model EShop.Models.Category
@{
    ViewData["Title"] = "حذف دسته‌بندی";
}

<div class="container" style="padding: 40px 20px; max-width: 600px;">
    <h1 style="color: var(--primary-navy); margin-bottom: 30px;"><i class="fas fa-trash"></i> حذف دسته‌بندی</h1>

    <div style="background: var(--white); border-radius: 15px; padding: 30px; box-shadow: var(--shadow);">
        <div style="text-align: center; margin-bottom: 20px;">
            <img src="@Model.ImageUrl" alt="@Model.Name" style="width: 150px; height: 100px; object-fit: cover; border-radius: 15px;" onerror="this.src='https://picsum.photos/seed/@Model.Id/150/100'" />
        </div>
        
        <h3 style="color: var(--primary-navy); text-align: center; margin-bottom: 20px;">@Model.Name</h3>
        
        <div style="background: var(--off-white); padding: 20px; border-radius: 10px; margin-bottom: 20px;">
            <p style="color: var(--gray); margin-bottom: 10px;">
                <strong>Description:</strong> @Model.Description
            </p>
            <p style="color: var(--gray);">
                <strong>Products:</strong> @Model.Products.Count
            </p>
        </div>

        @if (Model.Products.Count > 0)
        {
            <div class="alert alert-warning" style="text-align: center;">
                <i class="fas fa-exclamation-triangle"></i> This category has @Model.Products.Count products. Delete or move them first.
            </div>
        }
        else
        {
            <div class="alert alert-danger" style="text-align: center;">
                <i class="fas fa-exclamation-triangle"></i> Are you sure you want to delete this category?
            </div>
        }

        <form asp-action="Delete" method="post" style="display: flex; gap: 15px; margin-top: 20px;">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-primary" style="background: var(--danger); border-color: var(--danger); flex: 1;" @(Model.Products.Count > 0 ? "disabled" : "")>
                <i class="fas fa-trash"></i> Delete
            </button>
            <a href="/Admin/Categories" class="btn btn-outline" style="flex: 1;">
                <i class="fas fa-times"></i> Cancel
            </a>
        </form>
    </div>
</div>
