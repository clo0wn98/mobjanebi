@model List<EShop.Models.DiscountCode>
@{
    ViewData["Title"] = "کدهای تخفیف";
}

<div class="container" style="padding: 40px 20px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
        <h1 style="color: var(--primary-navy);"><i class="fas fa-tags"></i> کدهای تخفیف</h1>
        <a href="/Admin/DiscountCodes/Create" class="btn btn-primary"><i class="fas fa-plus"></i> افزودن کد تخفیف</a>
    </div>

    <div style="background: var(--white); border-radius: 15px; overflow: hidden; box-shadow: var(--shadow);">
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background: var(--primary-navy); color: white;">
                    <th style="padding: 15px; text-align: right;">کد</th>
                    <th style="padding: 15px; text-align: right;">نوع تخفیف</th>
                    <th style="padding: 15px; text-align: right;">مقدار</th>
                    <th style="padding: 15px; text-align: right;">حداقل خرید</th>
                    <th style="padding: 15px; text-align: right;">تاریخ پایان</th>
                    <th style="padding: 15px; text-align: right;">استفاده شده</th>
                    <th style="padding: 15px; text-align: right;">وضعیت</th>
                    <th style="padding: 15px; text-align: right;">عملیات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var code in Model)
                {
                    <tr style="border-bottom: 1px solid var(--gray-light);">
                        <td style="padding: 15px;">
                            <span style="background: var(--accent-orange); color: white; padding: 5px 12px; border-radius: 5px; font-weight: bold;">@code.Code</span>
                        </td>
                        <td style="padding: 15px;">
                            @if (code.DiscountType == "Percent")
                            {
                                <span>درصدی</span>
                            }
                            else
                            {
                                <span>مبلغ ثابت</span>
                            }
                        </td>
                        <td style="padding: 15px;">
                            @if (code.DiscountType == "Percent")
                            {
                                <span>@code.DiscountValue٪</span>
                            }
                            else
                            {
                                <span>@code.DiscountValue.ToString("N0") تومان</span>
                            }
                        </td>
                        <td style="padding: 15px;">@(code.MinOrderAmount?.ToString("N0") ?? "-") تومان</td>
                        <td style="padding: 15px;">@code.EndDate.ToString("yyyy/MM/dd")</td>
                        <td style="padding: 15px;">@code.UsageCount / @(code.MaxUsageCount?.ToString() ?? "∞")</td>
                        <td style="padding: 15px;">
                            @if (code.IsActive)
                            {
                                <span style="background: #d4edda; color: #155724; padding: 4px 10px; border-radius: 15px; font-size: 12px;">فعال</span>
                            }
                            else
                            {
                                <span style="background: #f8d7da; color: #721c24; padding: 4px 10px; border-radius: 15px; font-size: 12px;">غیرفعال</span>
                            }
                        </td>
                        <td style="padding: 15px;">
                            <a href="/Admin/DiscountCodes/Edit/@code.Id" class="btn btn-outline" style="padding: 6px 12px; font-size: 13px;"><i class="fas fa-edit"></i></a>
                            <a href="/Admin/DiscountCodes/Delete/@code.Id" class="btn btn-outline" style="padding: 6px 12px; font-size: 13px; background: var(--danger); border-color: var(--danger); color: white;"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div style="margin-top: 30px;">
        <a href="/Admin" class="btn btn-outline"><i class="fas fa-arrow-right"></i> بازگشت به داشبورد</a>
    </div>
</div>
