@model List<EShop.Models.Order>
@{
    ViewData["Title"] = "مدیریت سفارش‌ها";
}

<div class="container" style="padding: 40px 20px;">
    <h1 style="color: var(--primary-navy); margin-bottom: 30px;"><i class="fas fa-shopping-bag"></i> سفارش‌ها</h1>

    <div style="background: var(--white); border-radius: 15px; overflow: hidden; box-shadow: var(--shadow);">
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background: var(--primary-navy); color: white;">
                    <th style="padding: 15px; text-align: left;">Order #</th>
                    <th style="padding: 15px; text-align: left;">Customer</th>
                    <th style="padding: 15px; text-align: left;">Email</th>
                    <th style="padding: 15px; text-align: left;">Total</th>
                    <th style="padding: 15px; text-align: left;">Order Status</th>
                    <th style="padding: 15px; text-align: left;">Payment</th>
                    <th style="padding: 15px; text-align: left;">Date</th>
                    <th style="padding: 15px; text-align: left;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr style="border-bottom: 1px solid var(--gray-light);">
                        <td style="padding: 15px;"><strong style="color: var(--primary-navy);">#@order.Id</strong></td>
                        <td style="padding: 15px;">@order.FirstName @order.LastName</td>
                        <td style="padding: 15px; color: var(--gray);">@order.Email</td>
                        <td style="padding: 15px;"><span style="color: var(--accent-orange); font-weight: 600;">$@order.TotalAmount</span></td>
                        <td style="padding: 15px;">
                            <span style="padding: 4px 10px; border-radius: 15px; font-size: 12px; 
                                @(order.OrderStatus == "Delivered" ? "background: #d4edda; color: #155724;" : 
                                  order.OrderStatus == "Shipped" ? "background: #cce5ff; color: #004085;" : 
                                  "background: #fff3cd; color: #856404;");">
                                @order.OrderStatus
                            </span>
                        </td>
                        <td style="padding: 15px;">
                            <span style="padding: 4px 10px; border-radius: 15px; font-size: 12px; 
                                @(order.PaymentStatus == "Paid" ? "background: #d4edda; color: #155724;" : 
                                  "background: #fff3cd; color: #856404;");">
                                @order.PaymentStatus
                            </span>
                        </td>
                        <td style="padding: 15px; color: var(--gray);">@order.OrderDate.ToString("MMM dd, yyyy")</td>
                        <td style="padding: 15px;">
                            <a href="/Admin/Orders/Details/@order.Id" class="btn btn-outline" style="padding: 6px 12px; font-size: 13px;"><i class="fas fa-eye"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div style="margin-top: 30px;">
        <a href="/Admin" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back to Dashboard</a>
    </div>
</div>
