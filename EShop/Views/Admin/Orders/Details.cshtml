@model EShop.Models.Order
@{
    ViewData["Title"] = "جزئیات سفارش";
}

<div class="container" style="padding: 40px 20px;">
    <h1 style="color: var(--primary-navy); margin-bottom: 30px;"><i class="fas fa-receipt"></i> سفارش #@Model.Id</h1>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
        <div style="background: var(--white); border-radius: 15px; padding: 25px; box-shadow: var(--shadow);">
            <h3 style="color: var(--primary-navy); margin-bottom: 20px; padding-bottom: 15px; border-bottom: 2px solid var(--gray-light);">Order Information</h3>
            
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 20px;">
                <div>
                    <p style="color: var(--gray); font-size: 13px;">Order Date</p>
                    <p style="color: var(--primary-navy); font-weight: 600;">@Model.OrderDate.ToString("MMM dd, yyyy HH:mm")</p>
                </div>
                <div>
                    <p style="color: var(--gray); font-size: 13px;">Total Amount</p>
                    <p style="color: var(--accent-orange); font-weight: 700; font-size: 20px;">$@Model.TotalAmount</p>
                </div>
            </div>

            <form asp-action="UpdateStatus" method="post" style="background: var(--off-white); padding: 20px; border-radius: 10px;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                
                <div class="form-group">
                    <label>Order Status</label>
                    <select name="orderStatus" class="form-control">
                        <option value="Pending" selected="@(Model.OrderStatus == "Pending")">Pending</option>
                        <option value="Processing" selected="@(Model.OrderStatus == "Processing")">Processing</option>
                        <option value="Shipped" selected="@(Model.OrderStatus == "Shipped")">Shipped</option>
                        <option value="Delivered" selected="@(Model.OrderStatus == "Delivered")">Delivered</option>
                        <option value="Cancelled" selected="@(Model.OrderStatus == "Cancelled")">Cancelled</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Payment Status</label>
                    <select name="paymentStatus" class="form-control">
                        <option value="Pending" selected="@(Model.PaymentStatus == "Pending")">Pending</option>
                        <option value="Paid" selected="@(Model.PaymentStatus == "Paid")">Paid</option>
                        <option value="Refunded" selected="@(Model.PaymentStatus == "Refunded")">Refunded</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-primary" style="width: 100%;"><i class="fas fa-save"></i> Update Status</button>
            </form>
        </div>

        <div style="background: var(--white); border-radius: 15px; padding: 25px; box-shadow: var(--shadow);">
            <h3 style="color: var(--primary-navy); margin-bottom: 20px; padding-bottom: 15px; border-bottom: 2px solid var(--gray-light);">Customer Information</h3>
            
            <div style="line-height: 2;">
                <p><i class="fas fa-user" style="color: var(--accent-orange); width: 20px;"></i> @Model.FirstName @Model.LastName</p>
                <p><i class="fas fa-envelope" style="color: var(--accent-orange); width: 20px;"></i> @Model.Email</p>
                <p><i class="fas fa-phone" style="color: var(--accent-orange); width: 20px;"></i> @Model.Phone</p>
                <p><i class="fas fa-map-marker-alt" style="color: var(--accent-orange); width: 20px;"></i> @Model.Address, @Model.City, @Model.PostalCode</p>
                <p><i class="fas fa-globe" style="color: var(--accent-orange); width: 20px;"></i> @Model.Country</p>
            </div>
        </div>
    </div>

    <div style="background: var(--white); border-radius: 15px; padding: 25px; box-shadow: var(--shadow); margin-top: 30px;">
        <h3 style="color: var(--primary-navy); margin-bottom: 20px;">Order Items</h3>
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background: var(--primary-navy); color: white;">
                    <th style="padding: 12px; text-align: left;">Product</th>
                    <th style="padding: 12px; text-align: left;">Price</th>
                    <th style="padding: 12px; text-align: left;">Quantity</th>
                    <th style="padding: 12px; text-align: right;">Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.OrderItems)
                {
                    <tr style="border-bottom: 1px solid var(--gray-light);">
                        <td style="padding: 15px;">
                            <div style="display: flex; align-items: center; gap: 15px;">
                                <img src="@item.Product?.ImageUrl" alt="@item.Product?.Name" style="width: 50px; height: 50px; object-fit: cover; border-radius: 8px;" onerror="this.src='https://picsum.photos/seed/@item.ProductId/50/50'" />
                                <span style="color: var(--primary-navy); font-weight: 500;">@item.Product?.Name</span>
                            </div>
                        </td>
                        <td style="padding: 15px; color: var(--gray);">$@item.Price</td>
                        <td style="padding: 15px; color: var(--gray);">@item.Quantity</td>
                        <td style="padding: 15px; text-align: right; color: var(--accent-orange); font-weight: 600;">$@(item.Price * item.Quantity)</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="3" style="padding: 15px; text-align: right; font-weight: 600; color: var(--primary-navy);">Total:</td>
                    <td style="padding: 15px; text-align: right; font-weight: 700; color: var(--accent-orange); font-size: 18px;">$@Model.TotalAmount</td>
                </tr>
            </tfoot>
        </table>
    </div>

    <div style="margin-top: 30px;">
        <a href="/Admin/Orders" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back to Orders</a>
    </div>
</div>
