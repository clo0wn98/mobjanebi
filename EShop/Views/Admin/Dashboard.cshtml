@{
    ViewData["Title"] = "پنل مدیریت";
}

<div class="container" style="padding: 40px 20px;">
    <h1 style="color: var(--primary-navy); margin-bottom: 30px;"><i class="fas fa-tachometer-alt"></i> داشبورد مدیریت</h1>

    <!-- Stats Cards -->
    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 40px;">
        <div style="background: linear-gradient(135deg, var(--primary-navy) 0%, var(--primary-navy-light) 100%); padding: 25px; border-radius: 15px; color: white; box-shadow: var(--shadow);">
            <i class="fas fa-box" style="font-size: 32px; color: var(--accent-orange); margin-bottom: 15px;"></i>
            <h3 style="font-size: 32px; margin-bottom: 5px;">@ViewBag.TotalProducts</h3>
            <p style="opacity: 0.8;">کل محصولات</p>
        </div>
        <div style="background: linear-gradient(135deg, var(--accent-orange) 0%, var(--accent-orange-light) 100%); padding: 25px; border-radius: 15px; color: white; box-shadow: var(--shadow);">
            <i class="fas fa-shopping-bag" style="font-size: 32px; color: white; margin-bottom: 15px;"></i>
            <h3 style="font-size: 32px; margin-bottom: 5px;">@ViewBag.TotalOrders</h3>
            <p style="opacity: 0.8;">کل سفارش‌ها</p>
        </div>
        <div style="background: linear-gradient(135deg, #28a745 0%, #34ce57 100%); padding: 25px; border-radius: 15px; color: white; box-shadow: var(--shadow);">
            <i class="fas fa-dollar-sign" style="font-size: 32px; color: white; margin-bottom: 15px;"></i>
            <h3 style="font-size: 32px; margin-bottom: 5px;">@(ViewBag.TotalRevenue?.ToString("N0") ?? "0")</h3>
            <p style="opacity: 0.8;">درآمد کل (تومان)</p>
        </div>
        <div style="background: linear-gradient(135deg, #17a2b8 0%, #1abcde 100%); padding: 25px; border-radius: 15px; color: white; box-shadow: var(--shadow);">
            <i class="fas fa-users" style="font-size: 32px; color: white; margin-bottom: 15px;"></i>
            <h3 style="font-size: 32px; margin-bottom: 5px;">@ViewBag.TotalCustomers</h3>
            <p style="opacity: 0.8;">مشتریان</p>
        </div>
    </div>

    <!-- Quick Actions -->
    <div style="background: var(--white); border-radius: 15px; padding: 25px; box-shadow: var(--shadow); margin-bottom: 30px;">
        <h2 style="color: var(--primary-navy); margin-bottom: 20px;">دسترسی سریع</h2>
        <div style="display: grid; grid-template-columns: repeat(6, 1fr); gap: 15px;">
            <a href="/Admin/Products" class="btn btn-outline" style="padding: 15px; text-align: center;">
                <i class="fas fa-box" style="font-size: 24px; color: var(--accent-orange); margin-bottom: 8px;"></i>
                <br/>محصولات
            </a>
            <a href="/Admin/Categories" class="btn btn-outline" style="padding: 15px; text-align: center;">
                <i class="fas fa-tags" style="font-size: 24px; color: var(--accent-orange); margin-bottom: 8px;"></i>
                <br/>دسته‌بندی‌ها
            </a>
            <a href="/Admin/Orders" class="btn btn-outline" style="padding: 15px; text-align: center;">
                <i class="fas fa-shopping-bag" style="font-size: 24px; color: var(--accent-orange); margin-bottom: 8px;"></i>
                <br/>سفارش‌ها
            </a>
            <a href="/Admin/DiscountCodes" class="btn btn-outline" style="padding: 15px; text-align: center;">
                <i class="fas fa-tags" style="font-size: 24px; color: var(--accent-orange); margin-bottom: 8px;"></i>
                <br/>کد تخفیف
            </a>
            <a href="/Admin/Customers" class="btn btn-outline" style="padding: 15px; text-align: center;">
                <i class="fas fa-users" style="font-size: 24px; color: var(--accent-orange); margin-bottom: 8px;"></i>
                <br/>مشتریان
            </a>
            <a href="/Admin/Reports" class="btn btn-outline" style="padding: 15px; text-align: center;">
                <i class="fas fa-chart-line" style="font-size: 24px; color: var(--accent-orange); margin-bottom: 8px;"></i>
                <br/>گزارش‌ها
            </a>
        </div>
    </div>

    <!-- Recent Orders -->
    <div style="background: var(--white); border-radius: 15px; padding: 25px; box-shadow: var(--shadow);">
        <h2 style="color: var(--primary-navy); margin-bottom: 20px;">آخرین سفارش‌ها</h2>
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background: var(--primary-navy); color: white;">
                    <th style="padding: 12px; text-align: right;">شماره سفارش</th>
                    <th style="padding: 12px; text-align: right;">مشتری</th>
                    <th style="padding: 12px; text-align: right;">مبلغ</th>
                    <th style="padding: 12px; text-align: right;">وضعیت</th>
                    <th style="padding: 12px; text-align: right;">تاریخ</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in ViewBag.RecentOrders)
                {
                    <tr style="border-bottom: 1px solid var(--gray-light);">
                        <td style="padding: 12px;">#@order.Id</td>
                        <td style="padding: 12px;">@order.FirstName @order.LastName</td>
                        <td style="padding: 12px; color: var(--accent-orange); font-weight: 600;">@order.FinalAmount.ToString("N0") تومان</td>
                        <td style="padding: 12px;">
                            <span style="padding: 4px 10px; border-radius: 15px; font-size: 12px; 
                                @(order.OrderStatus == "Delivered" ? "background: #d4edda; color: #155724;" : 
                                  order.OrderStatus == "Shipped" ? "background: #cce5ff; color: #004085;" : 
                                  "background: #fff3cd; color: #856404;");">
                                @order.OrderStatus
                            </span>
                        </td>
                        <td style="padding: 12px;">@order.OrderDate.ToString("yyyy/MM/dd HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
