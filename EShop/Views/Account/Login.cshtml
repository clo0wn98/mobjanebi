@model EShop.Models.Account.LoginViewModel
@{
    ViewData["Title"] = "ورود به حساب کاربری";
}

<div class="auth-container">
    <div class="auth-box">
        <a href="/" class="logo">
            <img src="~/logo.png" alt="MobJanebi" style="height: 50px;" />
            <span style="margin-right: 10px; font-size: 24px; font-weight: 700; color: var(--primary-navy);">MobJanebi</span>
        </a>
        <h2>ورود به حساب کاربری</h2>
        <p>به فروشگاه MobJanebi خوش آمدید</p>

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

            <div asp-validation-summary="All" class="alert alert-danger"></div>

            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control" placeholder="ایمیل" />
                <span asp-validation-for="Email" class="text-danger" style="color: var(--danger); font-size: 12px;"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-control" placeholder="رمز عبور" />
                <span asp-validation-for="Password" class="text-danger" style="color: var(--danger); font-size: 12px;"></span>
            </div>

            <div class="form-group" style="display: flex; justify-content: space-between; align-items: center;">
                <label style="display: flex; align-items: center; margin: 0; cursor: pointer;">
                    <input asp-for="RememberMe" style="margin-left: 8px;" />
                    <span style="font-size: 14px; color: var(--gray-dark);">مرا به خاطر بسپار</span>
                </label>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 20px;">
                <i class="fas fa-sign-in-alt"></i> ورود با ایمیل
            </button>
        </form>

        <div style="text-align: center; margin-top: 20px;">
            <a href="/Account/LoginWithPhone" class="btn btn-outline" style="width: 100%; display: flex; align-items: center; justify-content: center; gap: 10px;">
                <i class="fas fa-mobile-alt"></i> ورود با شماره موبایل
            </a>
        </div>

        <div style="text-align: center; margin-top: 25px; color: var(--gray);">
            <p>حساب کاربری ندارید؟ <a href="/Account/Register" style="color: var(--accent-orange); font-weight: 600;">ثبت‌نام کنید</a></p>
        </div>
    </div>
</div>
