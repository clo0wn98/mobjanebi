@{
    ViewData["Title"] = "سیاست حفظ حریم خصوصی";
}

<div class="container" style="padding: 60px 20px; max-width: 800px;">
    <h1 style="color: var(--primary-navy); margin-bottom: 30px;">@ViewData["Title"]</h1>
    
    <div style="background: var(--white); padding: 40px; border-radius: 15px; box-shadow: var(--shadow);">
        <h2 style="color: var(--accent-orange); margin-bottom: 20px;">جمع‌آوری اطلاعات</h2>
        <p style="color: var(--gray-dark); line-height: 1.8; margin-bottom: 20px;">
            ما اطلاعات شما را هنگام ثبت‌نام در سایت، ثبت سفارش، عضویت در خبرنامه یا تکمیل فرم جمع‌آوری می‌کنیم.
        </p>

        <h2 style="color: var(--accent-orange); margin-bottom: 20px;">استفاده از اطلاعات</h2>
        <p style="color: var(--gray-dark); line-height: 1.8; margin-bottom: 20px;">
            اطلاعات جمع‌آوری شده برای بهبود تجربه خرید شما، پردازش سفارشات و ارتباط با شما استفاده می‌شود.
        </p>

        <h2 style="color: var(--accent-orange); margin-bottom: 20px;">محفاظت از اطلاعات</h2>
        <p style="color: var(--gray-dark); line-height: 1.8; margin-bottom: 20px;">
            ما از تدابیر امنیتی مناسب برای محافظت از اطلاعات شخصی شما استفاده می‌کنیم.
        </p>

        <h2 style="color: var(--accent-orange); margin-bottom: 20px;">تماس با ما</h2>
        <p style="color: var(--gray-dark); line-height: 1.8;">
            اگر سوالی درباره سیاست حفظ حریم خصوصی دارید، لطفاً با ما تماس بگیرید.
        </p>
    </div>
</div>
