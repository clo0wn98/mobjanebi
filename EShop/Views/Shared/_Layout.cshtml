<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - فروشگاه MobJanebi</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://cdn.jsdelivr.net/gh/rastikerdar/vazir-font@v30.1.0/dist/font-face.css" rel="stylesheet" />
</head>
<body>
    <header>
        <div class="top-bar">
            <div class="container">
                <span><i class="fas fa-phone"></i> ۰۲۱-۱۲۳۴۵۶۷۸</span>
                <div>
                    <a href="mailto:info@mobjanebi.ir"><i class="fas fa-envelope"></i> info@mobjanebi.ir</a>
                </div>
            </div>
        </div>
        <nav class="navbar">
            <div class="container" style="display: flex; align-items: center; justify-content: space-between;">
                <a href="/" class="logo"><img src="~/logo.png" alt="MobJanebi" /></a>
                
                <div style="display: flex; align-items: center; gap: 30px; flex: 1; justify-content: flex-end;">
                    <form asp-controller="Products" asp-action="Index" method="get" class="search-bar">
                        <input type="text" name="searchTerm" placeholder="جستجوی محصولات..." />
                        <button type="submit"><i class="fas fa-search"></i></button>
                    </form>

                    <ul class="nav-links">
                        <li><a href="/">خانه</a></li>
                        <li><a href="/Products">محصولات</a></li>
                        @await Component.InvokeAsync("MenuCategories")
                    </ul>

                    <div class="nav-icons">
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <a href="/Admin" title="پنل مدیریت" style="background: var(--accent-orange);"><i class="fas fa-cog"></i></a>
                            }
                            <a href="/Orders/MyOrders" title="سفارش‌های من" style="background: var(--primary-navy);"><i class="fas fa-clipboard-list"></i></a>
                            <form asp-controller="Account" asp-action="Logout" asp-area="" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" style="background:var(--accent-orange);border:none;color:white;width:40px;height:40px;border-radius:50%;cursor:pointer;font-size:18px;" title="خروج">
                                    <i class="fas fa-sign-out-alt"></i>
                                </button>
                            </form>
                        }
                        else
                        {
                            <a href="/Account/Login" title="ورود" style="background: var(--primary-navy);"><i class="fas fa-user"></i></a>
                        }
                        <a href="/Cart" class="cart-icon" style="position:relative; background: var(--accent-orange);" title="سبد خرید">
                            <i class="fas fa-shopping-cart"></i>
                            @await Component.InvokeAsync("CartCount")
                        </a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer>
        <div class="container">
            <div class="footer-grid">
                <div class="footer-col">
                    <h4>درباره فروشگاه</h4>
                    <p>فروشگاه آنلاین MobJanebi، مقصد شما برای خرید محصولات با کیفیت و قیمت مناسب.</p>
                    <div class="social-links">
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-telegram"></i></a>
                        <a href="#"><i class="fab fa-twitter"></i></a>
                        <a href="#"><i class="fab fa-linkedin-in"></i></a>
                    </div>
                </div>
                <div class="footer-col">
                    <h4>دسترسی سریع</h4>
                    <ul class="footer-links">
                        <li><a href="/Products">محصولات</a></li>
                        <li><a href="/Orders/MyOrders">سفارش‌های من</a></li>
                        <li><a href="/Cart">سبد خرید</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>تماس با ما</h4>
                    <ul class="footer-links">
                        <li><i class="fas fa-phone"></i> ۰۲۱-۱۲۳۴۵۶۷۸</li>
                        <li><i class="fas fa-envelope"></i> info@mobjanebi.ir</li>
                        <li><i class="fas fa-map-marker-alt"></i> تهران، ایران</li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>خدمات مشتریان</h4>
                    <ul class="footer-links">
                        <li><a href="#">رویه‌های بازگرداندن کالا</a></li>
                        <li><a href="#">سوالات متداول</a></li>
                        <li><a href="#">قوانین و مقررات</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>© ۱۴۰۴ - تمامی حقوق برای فروشگاه MobJanebi محفوظ است.</p>
            </div>
        </div>
    </footer>

    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
