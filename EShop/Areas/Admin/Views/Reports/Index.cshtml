@{
    ViewData["Title"] = "گزارشات";
}

<div class="container" style="padding: 40px 20px;">
    <h1 style="color: var(--primary-navy); margin-bottom: 30px;"><i class="fas fa-chart-line"></i> گزارشات فروش</h1>

    <!-- Stats Cards -->
    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 40px;">
        <div style="background: linear-gradient(135deg, var(--primary-navy) 0%, var(--primary-navy-light) 100%); padding: 25px; border-radius: 15px; color: white; box-shadow: var(--shadow);">
            <i class="fas fa-shopping-bag" style="font-size: 32px; color: var(--accent-orange); margin-bottom: 15px;"></i>
            <h3 style="font-size: 32px; margin-bottom: 5px;">@ViewBag.TotalOrders</h3>
            <p style="opacity: 0.8;">کل سفارش‌ها</p>
        </div>
        <div style="background: linear-gradient(135deg, #28a745 0%, #34ce57 100%); padding: 25px; border-radius: 15px; color: white; box-shadow: var(--shadow);">
            <i class="fas fa-dollar-sign" style="font-size: 32px; color: white; margin-bottom: 15px;"></i>
            <h3 style="font-size: 32px; margin-bottom: 5px;">@(((decimal)ViewBag.TotalRevenue).ToString("N0"))</h3>
            <p style="opacity: 0.8;">درآمد کل (تومان)</p>
        </div>
        <div style="background: linear-gradient(135deg, var(--accent-orange) 0%, var(--accent-orange-light) 100%); padding: 25px; border-radius: 15px; color: white; box-shadow: var(--shadow);">
            <i class="fas fa-box" style="font-size: 32px; color: white; margin-bottom: 15px;"></i>
            <h3 style="font-size: 32px; margin-bottom: 5px;">@ViewBag.TotalProducts</h3>
            <p style="opacity: 0.8;">محصولات</p>
        </div>
        <div style="background: linear-gradient(135deg, #dc3545 0%, #e4606d 100%); padding: 25px; border-radius: 15px; color: white; box-shadow: var(--shadow);">
            <i class="fas fa-exclamation-triangle" style="font-size: 32px; color: white; margin-bottom: 15px;"></i>
            <h3 style="font-size: 32px; margin-bottom: 5px;">@ViewBag.LowStockProducts</h3>
            <p style="opacity: 0.8;">کالاهای کم موجود</p>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
        <!-- Monthly Sales -->
        <div style="background: var(--white); border-radius: 15px; padding: 25px; box-shadow: var(--shadow);">
            <h3 style="color: var(--primary-navy); margin-bottom: 20px;">فروش ماهانه (۶ ماه گذشته)</h3>
            @if (ViewBag.MonthlySales != null && ((List<dynamic>)ViewBag.MonthlySales).Any())
            {
                <table style="width: 100%; border-collapse: collapse;">
                    <thead>
                        <tr style="background: var(--primary-navy); color: white;">
                            <th style="padding: 10px; text-align: right;">ماه</th>
                            <th style="padding: 10px; text-align: right;">تعداد سفارش</th>
                            <th style="padding: 10px; text-align: right;">درآمد</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in ViewBag.MonthlySales)
                        {
                            <tr style="border-bottom: 1px solid var(--gray-light);">
                                <td style="padding: 10px;">@item.Year/@item.Month</td>
                                <td style="padding: 10px;">@item.Count</td>
                                <td style="padding: 10px; color: var(--accent-orange); font-weight: 600;">@item.Total.ToString("N0") تومان</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p style="color: var(--gray);">داده‌ای یافت نشد</p>
            }
        </div>

        <!-- Top Products -->
        <div style="background: var(--white); border-radius: 15px; padding: 25px; box-shadow: var(--shadow);">
            <h3 style="color: var(--primary-navy); margin-bottom: 20px;">محصولات پرفروش</h3>
            @if (ViewBag.TopProducts != null && ((List<dynamic>)ViewBag.TopProducts).Any())
            {
                <table style="width: 100%; border-collapse: collapse;">
                    <thead>
                        <tr style="background: var(--primary-navy); color: white;">
                            <th style="padding: 10px; text-align: right;">محصول</th>
                            <th style="padding: 10px; text-align: right;">فروش</th>
                            <th style="padding: 10px; text-align: right;">درآمد</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in ViewBag.TopProducts)
                        {
                            <tr style="border-bottom: 1px solid var(--gray-light);">
                                <td style="padding: 10px;">@item.ProductName</td>
                                <td style="padding: 10px;">@item.TotalSold</td>
                                <td style="padding: 10px; color: var(--accent-orange); font-weight: 600;">@item.TotalRevenue.ToString("N0") تومان</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p style="color: var(--gray);">داده‌ای یافت نشد</p>
            }
        </div>
    </div>

    <!-- Quick Links -->
    <div style="background: var(--white); border-radius: 15px; padding: 25px; box-shadow: var(--shadow); margin-top: 30px;">
        <h3 style="color: var(--primary-navy); margin-bottom: 20px;">گزارشات بیشتر</h3>
        <div style="display: flex; gap: 15px;">
            <a href="/Admin/Reports/Profit" class="btn btn-primary"><i class="fas fa-coins"></i> گزارش سود و زیان</a>
        </div>
    </div>
</div>
