@model EShop.Models.Product
@{
    ViewData["Title"] = "حذف محصول";
}

<div class="container" style="padding: 40px 20px; max-width: 700px;">
    <h1 style="color: var(--primary-navy); margin-bottom: 30px;"><i class="fas fa-trash"></i> حذف محصول</h1>

    <div style="background: var(--white); border-radius: 15px; padding: 30px; box-shadow: var(--shadow);">
        <div style="text-align: center; margin-bottom: 20px;">
            <img src="@Model.ImageUrl" alt="@Model.Name" style="width: 200px; height: 200px; object-fit: cover; border-radius: 15px;" onerror="this.src='https://picsum.photos/seed/@Model.Id/200/200'" />
        </div>
        
        <h3 style="color: var(--primary-navy); text-align: center; margin-bottom: 20px;">@Model.Name</h3>
        
        <div style="background: var(--off-white); padding: 20px; border-radius: 10px; margin-bottom: 20px;">
            <p style="color: var(--gray); margin-bottom: 10px;">
                <strong>دسته‌بندی:</strong> @Model.Category?.Name
            </p>
            <p style="color: var(--gray); margin-bottom: 10px;">
                <strong>SKU:</strong> @(Model.SKU ?? "-")
            </p>
            <p style="color: var(--gray); margin-bottom: 10px;">
                <strong>قیمت:</strong> 
                @if (Model.DiscountPrice.HasValue)
                {
                    <span style="color: var(--accent-orange); font-weight: 600;">@Model.DiscountPrice.Value.ToString("N0") تومان</span>
                    <span style="color: var(--gray); text-decoration: line-through; margin-right: 10px;">@Model.Price.ToString("N0") تومان</span>
                }
                else
                {
                    <span style="color: var(--accent-orange); font-weight: 600;">@Model.Price.ToString("N0") تومان</span>
                }
            </p>
            <p style="color: var(--gray); margin-bottom: 10px;">
                <strong>موجودی:</strong> @Model.Stock عدد
            </p>
            @if (Model.Attributes != null && Model.Attributes.Any())
            {
                <p style="color: var(--gray);">
                    <strong>ویژگی‌ها:</strong>
                    @string.Join("، ", Model.Attributes.Select(a => $"{a.Name}: {a.Value}"))
                </p>
            }
        </div>

        <div class="alert alert-danger" style="text-align: center; background: #f8d7da; color: #721c24; padding: 15px; border-radius: 8px; border: 1px solid #f5c6cb;">
            <i class="fas fa-exclamation-triangle"></i> آیا از حذف این محصول اطمینان دارید؟ این عملیات غیرقابل بازگشت است.
        </div>

        <form asp-action="Delete" method="post" style="display: flex; gap: 15px; margin-top: 20px;">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-primary" style="background: var(--danger); border-color: var(--danger); flex: 1;">
                <i class="fas fa-trash"></i> حذف محصول
            </button>
            <a href="/Admin/Products" class="btn btn-outline" style="flex: 1;">
                <i class="fas fa-times"></i> انصراف
            </a>
        </form>
    </div>
</div>
