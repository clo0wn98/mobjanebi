@model EShop.Models.Product
@{
    ViewData["Title"] = "جزئیات محصول";
}

<div class="container" style="padding: 40px 20px; max-width: 900px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
        <h1 style="color: var(--primary-navy);"><i class="fas fa-eye"></i> جزئیات محصول</h1>
        <a href="/Admin/Products" class="btn btn-outline"><i class="fas fa-arrow-right"></i> بازگشت به لیست</a>
    </div>

    <div style="background: var(--white); border-radius: 15px; padding: 30px; box-shadow: var(--shadow);">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
            <div>
                <img src="@Model.ImageUrl" alt="@Model.Name" style="width: 100%; border-radius: 15px;" onerror="this.src='https://picsum.photos/seed/@Model.Id/500/500'" />
            </div>
            <div>
                <h2 style="color: var(--primary-navy); margin-bottom: 15px;">@Model.Name</h2>
                
                @if (!string.IsNullOrEmpty(Model.SKU))
                {
                    <p style="color: var(--gray); margin-bottom: 15px;">
                        <strong>SKU:</strong> @Model.SKU
                    </p>
                }

                <div style="margin-bottom: 20px;">
                    @if (Model.DiscountPrice.HasValue)
                    {
                        <div style="font-size: 28px; color: var(--accent-orange); font-weight: 700;">
                            @Model.DiscountPrice.Value.ToString("N0") تومان
                        </div>
                        <div style="font-size: 18px; color: var(--gray); text-decoration: line-through;">
                            @Model.Price.ToString("N0") تومان
                        </div>
                        <span style="background: var(--accent-orange); color: white; padding: 4px 12px; border-radius: 15px; font-size: 13px;">
                            @(((Model.Price - Model.DiscountPrice.Value) / Model.Price * 100).ToString("N0"))٪ تخفیف
                        </span>
                    }
                    else
                    {
                        <div style="font-size: 28px; color: var(--accent-orange); font-weight: 700;">
                            @Model.Price.ToString("N0") تومان
                        </div>
                    }
                </div>

                <div style="margin-bottom: 20px;">
                    <p><strong>دسته‌بندی:</strong> @Model.Category?.Name</p>
                    <p><strong>موجودی:</strong> 
                        <span style="color: @(Model.Stock > 0 ? "var(--success)" : "var(--danger)");">
                            @(Model.Stock > 0 ? Model.Stock.ToString() + " عدد" : "ناموجود")
                        </span>
                    </p>
                    @if (Model.IsFeatured)
                    {
                        <p><strong>ویژه:</strong> <span style="color: var(--success);">بله</span></p>
                    }
                </div>

                <div style="margin-bottom: 20px;">
                    <strong>توضیحات:</strong>
                    <p style="color: var(--gray-dark); line-height: 1.8;">@Model.Description</p>
                </div>

                @if (Model.Attributes != null && Model.Attributes.Any())
                {
                    <div>
                        <strong>ویژگی‌ها:</strong>
                        <div style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 10px;">
                            @foreach (var attr in Model.Attributes)
                            {
                                <span style="background: var(--gray-light); padding: 8px 15px; border-radius: 20px; font-size: 14px;">
                                    <strong>@attr.Name:</strong> @attr.Value
                                </span>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <div style="display: flex; gap: 15px; margin-top: 30px; padding-top: 20px; border-top: 2px solid var(--gray-light);">
            <a href="/Admin/Products/Edit/@Model.Id" class="btn btn-primary"><i class="fas fa-edit"></i> ویرایش محصول</a>
            <a href="/Admin/Products/Delete/@Model.Id" class="btn btn-outline" style="background: var(--danger); border-color: var(--danger); color: white;"><i class="fas fa-trash"></i> حذف محصول</a>
        </div>
    </div>
</div>
