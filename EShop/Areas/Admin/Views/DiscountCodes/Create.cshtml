@model EShop.Models.DiscountCode
@{
    ViewData["Title"] = "افزودن کد تخفیف";
}

<div class="container" style="padding: 40px 20px; max-width: 800px;">
    <h1 style="color: var(--primary-navy); margin-bottom: 30px;"><i class="fas fa-plus"></i> افزودن کد تخفیف جدید</h1>

    <div style="background: var(--white); border-radius: 15px; padding: 30px; box-shadow: var(--shadow);">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            
            <div class="form-group">
                <label asp-for="Code"></label>
                <input asp-for="Code" class="form-control" placeholder="مثال: OFF20" required />
                <span style="color: var(--gray); font-size: 13px;">کد به صورت خودکار به حروف بزرگ تبدیل می‌شود</span>
            </div>

            <div class="form-group">
                <label asp-for="Description"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="DiscountType"></label>
                    <select asp-for="DiscountType" class="form-control" id="discountType">
                        <option value="Percent">درصدی (٪)</option>
                        <option value="Fixed">مبلغ ثابت (تومان)</option>
                    </select>
                </div>
                <div class="form-group">
                    <label asp-for="DiscountValue"></label>
                    <input asp-for="DiscountValue" class="form-control" type="number" step="0.01" id="discountValue" required />
                    <span id="discountValueHelp" style="color: var(--gray); font-size: 13px;"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="MinOrderAmount"></label>
                    <input asp-for="MinOrderAmount" class="form-control" type="number" step="1000" />
                    <span style="color: var(--gray); font-size: 13px;">حداقل مبلغ خرید برای استفاده از کد (اختیاری)</span>
                </div>
                <div class="form-group">
                    <label asp-for="MaxDiscountAmount"></label>
                    <input asp-for="MaxDiscountAmount" class="form-control" type="number" step="1000" />
                    <span style="color: var(--gray); font-size: 13px;">سقف مبلغ تخفیف (اختیاری)</span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="StartDate"></label>
                    <input asp-for="StartDate" class="form-control" type="datetime-local" />
                </div>
                <div class="form-group">
                    <label asp-for="EndDate"></label>
                    <input asp-for="EndDate" class="form-control" type="datetime-local" required />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="MaxUsageCount"></label>
                    <input asp-for="MaxUsageCount" class="form-control" type="number" />
                    <span style="color: var(--gray); font-size: 13px;">حداکثر تعداد استفاده (خالی = نامحدود)</span>
                </div>
                <div class="form-group">
                    <label style="display: flex; align-items: center; gap: 10px; cursor: pointer; margin-top: 35px;">
                        <input asp-for="IsActive" checked />
                        <span>کد فعال باشد</span>
                    </label>
                </div>
            </div>

            <div class="form-group">
                <label style="display: flex; align-items: center; gap: 10px; cursor: pointer;">
                    <input asp-for="IsForNewUsers" />
                    <span>فقط برای کاربران جدید (اولین خرید)</span>
                </label>
            </div>

            <div style="display: flex; gap: 15px; margin-top: 30px;">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> ذخیره کد تخفیف</button>
                <a href="/Admin/DiscountCodes" class="btn btn-outline"><i class="fas fa-times"></i> انصراف</a>
            </div>
        </form>
    </div>
</div>

<script>
    document.getElementById('discountType').addEventListener('change', function() {
        var helpText = document.getElementById('discountValueHelp');
        if (this.value === 'Percent') {
            helpText.textContent = 'درصد تخفیف را وارد کنید (مثال: 20 برای 20٪)';
        } else {
            helpText.textContent = 'مبلغ تخفیف به تومان را وارد کنید';
        }
    });
</script>
