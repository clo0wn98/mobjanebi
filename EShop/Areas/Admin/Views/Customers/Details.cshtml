@model Microsoft.AspNetCore.Identity.IdentityUser
@{
    ViewData["Title"] = "جزئیات مشتری";
    var roles = ViewBag.Roles as IList<string> ?? new List<string>();
    var orders = ViewBag.Orders as List<EShop.Models.Order> ?? new List<EShop.Models.Order>();
}

<div class="container" style="padding: 40px 20px;">
    <h1 style="color: var(--primary-navy); margin-bottom: 30px;"><i class="fas fa-user"></i> جزئیات مشتری</h1>

    <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 30px;">
        <div style="background: var(--white); border-radius: 15px; padding: 25px; box-shadow: var(--shadow);">
            <h3 style="color: var(--primary-navy); margin-bottom: 20px;">اطلاعات کاربر</h3>
            <p style="margin-bottom: 10px;"><strong>ایمیل:</strong> @Model.Email</p>
            <p style="margin-bottom: 10px;"><strong>نام کاربری:</strong> @Model.UserName</p>
            <p style="margin-bottom: 10px;"><strong>ایمیل تأیید شده:</strong> @(Model.EmailConfirmed ? "بله" : "خیر")</p>
            <p style="margin-bottom: 10px;"><strong>شماره تلفن:</strong> @(Model.PhoneNumber ?? "-")</p>
            <p style="margin-bottom: 20px;"><strong>نقش‌ها:</strong></p>
            <div>
                @foreach (var role in roles)
                {
                    <span style="padding: 5px 12px; border-radius: 15px; font-size: 14px; background: var(--accent-orange); color: white; margin-left: 5px;">
                        @role
                    </span>
                }
            </div>
        </div>

        <div style="background: var(--white); border-radius: 15px; padding: 25px; box-shadow: var(--shadow);">
            <h3 style="color: var(--primary-navy); margin-bottom: 20px;">سفارش‌های مشتری</h3>
            @if (orders.Any())
            {
                <table style="width: 100%; border-collapse: collapse;">
                    <thead>
                        <tr style="background: var(--primary-navy); color: white;">
                            <th style="padding: 10px; text-align: right;">شماره سفارش</th>
                            <th style="padding: 10px; text-align: right;">مبلغ</th>
                            <th style="padding: 10px; text-align: right;">وضعیت</th>
                            <th style="padding: 10px; text-align: right;">تاریخ</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in orders)
                        {
                            <tr style="border-bottom: 1px solid var(--gray-light);">
                                <td style="padding: 10px;">#@order.Id</td>
                                <td style="padding: 10px; color: var(--accent-orange); font-weight: 600;">@order.FinalAmount.ToString("N0") تومان</td>
                                <td style="padding: 10px;">
                                    <span style="padding: 4px 10px; border-radius: 15px; font-size: 12px; background: #fff3cd; color: #856404;">
                                        @order.OrderStatus
                                    </span>
                                </td>
                                <td style="padding: 10px;">@order.OrderDate.ToString("yyyy/MM/dd")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p style="color: var(--gray);">هیچ سفارشی یافت نشد</p>
            }
        </div>
    </div>

    <div style="margin-top: 20px;">
        <a href="/Admin/Customers" class="btn btn-outline"><i class="fas fa-arrow-right"></i> بازگشت به لیست</a>
    </div>
</div>
