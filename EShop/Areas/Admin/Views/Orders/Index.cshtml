@model List<EShop.Models.Order>
@{
    ViewData["Title"] = "سفارش‌ها";
}

<div class="container" style="padding: 40px 20px;">
    <h1 style="color: var(--primary-navy); margin-bottom: 30px;"><i class="fas fa-shopping-bag"></i> مدیریت سفارش‌ها</h1>

    <div style="background: var(--white); border-radius: 15px; overflow: hidden; box-shadow: var(--shadow);">
        @if (Model.Any())
        {
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background: var(--primary-navy); color: white;">
                    <th style="padding: 15px; text-align: right;">شماره سفارش</th>
                    <th style="padding: 15px; text-align: right;">مشتری</th>
                    <th style="padding: 15px; text-align: right;">ایمیل</th>
                    <th style="padding: 15px; text-align: right;">مبلغ</th>
                    <th style="padding: 15px; text-align: right;">وضعیت</th>
                    <th style="padding: 15px; text-align: right;">پرداخت</th>
                    <th style="padding: 15px; text-align: right;">تاریخ</th>
                    <th style="padding: 15px; text-align: right;">عملیات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr style="border-bottom: 1px solid var(--gray-light);">
                        <td style="padding: 15px;"><strong style="color: var(--primary-navy);">#@order.Id</strong></td>
                        <td style="padding: 15px;">@order.FirstName @order.LastName</td>
                        <td style="padding: 15px; color: var(--gray);">@order.Email</td>
                        <td style="padding: 15px;"><span style="color: var(--accent-orange); font-weight: 600;">@order.TotalAmount.ToString("N0") تومان</span></td>
                        <td style="padding: 15px;">
                            <span style="padding: 4px 10px; border-radius: 15px; font-size: 12px; 
                                @(order.OrderStatus == "Delivered" ? "background: #d4edda; color: #155724;" : 
                                  order.OrderStatus == "Shipped" ? "background: #cce5ff; color: #004085;" : 
                                  "background: #fff3cd; color: #856404;");">
                                @order.OrderStatus
                            </span>
                        </td>
                        <td style="padding: 15px;">
                            <span style="padding: 4px 10px; border-radius: 15px; font-size: 12px; 
                                @(order.PaymentStatus == "Paid" ? "background: #d4edda; color: #155724;" : 
                                  "background: #fff3cd; color: #856404;");">
                                @order.PaymentStatus
                            </span>
                        </td>
                        <td style="padding: 15px; color: var(--gray);">@order.OrderDate.ToString("yyyy/MM/dd")</td>
                        <td style="padding: 15px;">
                            <a href="/Admin/Orders/Details/@order.Id" class="btn btn-outline" style="padding: 6px 12px; font-size: 13px;"><i class="fas fa-eye"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        }
        else
        {
            <div style="padding: 40px; text-align: center; color: var(--gray);">
                <i class="fas fa-shopping-bag" style="font-size: 48px; margin-bottom: 15px;"></i>
                <p>هیچ سفارشی یافت نشد</p>
            </div>
        }
    </div>

    <div style="margin-top: 30px;">
        <a href="/Admin" class="btn btn-outline"><i class="fas fa-arrow-right"></i> بازگشت به داشبورد</a>
    </div>
</div>
