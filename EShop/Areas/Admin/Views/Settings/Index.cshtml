@model EShop.Models.AdminSettings

@{
    ViewData["Title"] = "تنظیمات";
    Layout = "_Layout";
}

<div class="content-card">
    <h2 style="margin-bottom: 20px; color: var(--primary-navy);">
        <i class="fas fa-cog"></i> تنظیمات پیامک
    </h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            <i class="fas fa-check-circle"></i> @TempData["Success"]
        </div>
    }

    <form method="post">
        <div class="form-group">
            <label style="font-weight: bold; display: block; margin-bottom: 10px;">
                <i class="fas fa-phone"></i> شماره‌های مدیر برای دریافت پیامک سفارشات
            </label>
            <p style="color: var(--gray); font-size: 14px; margin-bottom: 15px;">
                شماره موبایل مدیران را با کاما (,) جدا کنید. این شماره‌ها هنگام ثبت سفارش جدید پیامک دریافت می‌کنند.
            </p>
            <input type="text" name="adminPhones" class="form-control" 
                   value="@Model.SettingValue" 
                   placeholder="مثال: 09931234567, 09123456789" />
        </div>

        <div style="margin-top: 25px;">
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save"></i> ذخیره تنظیمات
            </button>
        </div>
    </form>
</div>

<style>
    .content-card {
        background: var(--white);
        border-radius: 10px;
        padding: 30px;
        box-shadow: var(--shadow);
    }
    .alert {
        padding: 15px 20px;
        border-radius: 8px;
        margin-bottom: 20px;
    }
    .alert-success {
        background: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
    }
    .form-group {
        margin-bottom: 20px;
    }
    .form-control {
        width: 100%;
        padding: 12px 15px;
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        font-size: 14px;
        transition: border-color 0.3s;
    }
    .form-control:focus {
        outline: none;
        border-color: var(--primary-navy);
    }
    .btn {
        padding: 12px 25px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-size: 14px;
        font-weight: bold;
        transition: all 0.3s;
    }
    .btn-primary {
        background: var(--primary-navy);
        color: white;
    }
    .btn-primary:hover {
        background: var(--primary-navy-light);
    }
</style>
