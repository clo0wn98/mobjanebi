@model EShop.Models.Category
@{
    ViewData["Title"] = "ویرایش دسته‌بندی";
}

<div class="container" style="padding: 40px 20px; max-width: 600px;">
    <h1 style="color: var(--primary-navy); margin-bottom: 30px;"><i class="fas fa-edit"></i> ویرایش دسته‌بندی</h1>

    <div style="background: var(--white); border-radius: 15px; padding: 30px; box-shadow: var(--shadow);">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            
            <div class="form-group">
                <label asp-for="Name"></label>
                <input asp-for="Name" class="form-control" required />
            </div>

            <div class="form-group">
                <label asp-for="Description"></label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            </div>

            <div class="form-group">
                <label asp-for="ImageUrl"></label>
                <input asp-for="ImageUrl" class="form-control" />
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="@Model.Name" style="width: 150px; height: 100px; object-fit: cover; border-radius: 8px; margin-top: 10px;" onerror="this.src='https://picsum.photos/seed/@Model.Id/150/100'" />
                }
            </div>

            <div class="form-group">
                <label style="display: flex; align-items: center; gap: 10px; cursor: pointer;">
                    <input asp-for="ShowInMenu" />
                    <span>نمایش در منوی ناوبری</span>
                </label>
                <span style="color: var(--gray); font-size: 13px; display: block; margin-top: 5px;">اگر این گزینه فعال باشد، این دسته‌بندی در منوی سایت نمایش داده می‌شود</span>
            </div>

            <div style="display: flex; gap: 15px; margin-top: 30px;">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Update Category</button>
                <a href="/Admin/Categories" class="btn btn-outline"><i class="fas fa-times"></i> Cancel</a>
            </div>
        </form>
    </div>
</div>
