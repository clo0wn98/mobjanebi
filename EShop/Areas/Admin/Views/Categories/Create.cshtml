@model EShop.Models.Category
@{
    ViewData["Title"] = "افزودن دسته‌بندی";
}

<div class="container" style="padding: 40px 20px; max-width: 600px;">
    <h1 style="color: var(--primary-navy); margin-bottom: 30px;"><i class="fas fa-plus"></i> افزودن دسته‌بندی جدید</h1>

    <div style="background: var(--white); border-radius: 15px; padding: 30px; box-shadow: var(--shadow);">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            
            <div class="form-group">
                <label asp-for="Name"></label>
                <input asp-for="Name" class="form-control" required />
            </div>

            <div class="form-group">
                <label asp-for="Description"></label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            </div>

            <div class="form-group">
                <label asp-for="ImageUrl"></label>
                <input asp-for="ImageUrl" class="form-control" placeholder="https://picsum.photos/seed/categoryname/400/300" />
            </div>

            <div class="form-group">
                <label style="display: flex; align-items: center; gap: 10px; cursor: pointer;">
                    <input asp-for="ShowInMenu" />
                    <span>نمایش در منوی ناوبری</span>
                </label>
                <span style="color: var(--gray); font-size: 13px; display: block; margin-top: 5px;">اگر این گزینه فعال باشد، این دسته‌بندی در منوی سایت نمایش داده می‌شود</span>
            </div>

            <div style="display: flex; gap: 15px; margin-top: 30px;">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> ذخیره دسته‌بندی</button>
                <a href="/Admin/Categories" class="btn btn-outline"><i class="fas fa-times"></i> انصراف</a>
            </div>
        </form>
    </div>
</div>
